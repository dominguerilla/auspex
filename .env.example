# Copy this file to .env and fill in your values.
# The graph reads OLLAMA_MODEL at startup via get_llm() in llm/ollama_client.py.
# Changing this value is the only thing needed to swap models — no Python edits required.

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Optional: LangSmith tracing (Phase 6)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_key_here
# LANGCHAIN_PROJECT=researcher
